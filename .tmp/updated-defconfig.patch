diff --git a/scripts/package-build/linux-kernel/config/00-bpf-btf.config b/scripts/package-build/linux-kernel/config/00-bpf-btf.config
new file mode 100644
index 00000000..00000000
--- /dev/null
+++ b/scripts/package-build/linux-kernel/config/00-bpf-btf.config
@@ -0,0 +1,56 @@
+#
+# BPF/BTF Configuration for VyOS Kernel 6.18.20
+# Enables modern eBPF, BTF, XDP, and BPF-based networking features
+#
+
+# Core BPF Support
+CONFIG_BPF=y
+CONFIG_BPF_SYSCALL=y
+CONFIG_BPF_JIT=y
+CONFIG_BPF_JIT_ALWAYS_ON=y
+CONFIG_BPF_JIT_DEFAULT_ON=y
+
+# BTF (BPF Type Format) Support
+CONFIG_DEBUG_INFO_BTF=y
+CONFIG_DEBUG_INFO_BTF_MODULES=y
+CONFIG_PAHOLE_HAS_SPLIT_BTF=y
+
+# BPF Program Types
+CONFIG_BPF_EVENTS=y
+CONFIG_BPF_KPROBE_OVERRIDE=y
+CONFIG_BPF_STREAM_PARSER=y
+
+# Networking BPF
+CONFIG_NET_CLS_BPF=m
+CONFIG_NET_ACT_BPF=m
+CONFIG_LWTUNNEL_BPF=y
+CONFIG_NETFILTER_XT_MATCH_BPF=m
+
+# XDP (eXpress Data Path)
+CONFIG_XDP_SOCKETS=y
+CONFIG_XDP_SOCKETS_DIAG=y
+
+# BPF LSM (Linux Security Module)
+CONFIG_BPF_LSM=y
+
+# cgroup BPF
+CONFIG_CGROUP_BPF=y
+CONFIG_SOCK_CGROUP_DATA=y
+
+# BPF Infrastructure
+CONFIG_BPF_LIRC_MODE2=y
+CONFIG_BPFILTER=y
+CONFIG_BPFILTER_UMH=m
+
+# Tracing & Observability (BPF dependencies)
+CONFIG_FTRACE=y
+CONFIG_KPROBES=y
+CONFIG_KPROBE_EVENTS=y
+CONFIG_UPROBE_EVENTS=y
+CONFIG_TRACEPOINTS=y
+CONFIG_PERF_EVENTS=y
+
+# Debug Info (required for BTF generation)
+CONFIG_DEBUG_INFO=y
+CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
+
+# Dependencies
+CONFIG_KALLSYMS=y
+CONFIG_KALLSYMS_ALL=y
