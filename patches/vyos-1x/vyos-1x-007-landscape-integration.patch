+# GNU General Public License for more details.
+#
+# You should have received a copy of the GNU General Public License
+# along with this program.  If not, see <http://www.gnu.org/licenses/>.
+
+import os
+
+from sys import exit
+from vyos.config import Config
+from vyos.template import render
+from vyos.utils.process import call
+from vyos import ConfigError
+from vyos import airbag
+airbag.enable()
+
+service_name = 'landscape-router'
+service_conf = '/run/landscape/landscape.env'
+
+def get_config(config=None):
+    if config:
+        conf = config
+    else:
+        conf = Config()
+
+    base = ['service', 'landscape']
+    if not conf.exists(base):
+        return None
+
+    landscape = conf.get_config_dict(base, key_mangling=('-', '_'),
+                                     get_first_key=True)
+    return landscape
+
+def verify(landscape):
+    if not landscape:
+        return None
+
+    return None
+
+def generate(landscape):
+    if not landscape:
+        return None
+
+    # Create config directory
+    config_dir = landscape.get('config_dir', '/config/landscape')
+    os.makedirs(config_dir, exist_ok=True)
+
+    # Create environment file for systemd
+    os.makedirs('/run/landscape', exist_ok=True)
+
+    with open(service_conf, 'w') as f:
+        f.write(f"HTTP_PORT={landscape.get('http_port', '6300')}\n")
+        f.write(f"HTTPS_PORT={landscape.get('https_port', '6443')}\n")
+        f.write(f"CONFIG_DIR={config_dir}\n")
+
+    return None
+
+def apply(landscape):
+    if not landscape or 'enable' not in landscape:
+        # Stop service
+        call(f'systemctl stop {service_name}.service')
+        call(f'systemctl disable {service_name}.service')
+        if os.path.exists(service_conf):
+            os.unlink(service_conf)
+        return None
+
+    # Start service
+    call(f'systemctl daemon-reload')
+    call(f'systemctl enable {service_name}.service')
+    call(f'systemctl restart {service_name}.service')
+
+    return None
+
+if __name__ == '__main__':
+    try:
+        c = get_config()
+        verify(c)
+        generate(c)
+        apply(c)
+    except ConfigError as e:
+        print(e)
+        exit(1)
