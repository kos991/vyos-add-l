@@ -0,0 +1,57 @@
+<?xml version="1.0"?>
+<interfaceDefinition>
+  <node name="service">
+    <children>
+      <node name="landscape" owner="${vyos_conf_scripts_dir}/service_landscape.py">
+        <properties>
+          <help>Landscape eBPF Router</help>
+          <priority>500</priority>
+        </properties>
+        <children>
+          <leafNode name="enable">
+            <properties>
+              <help>Enable Landscape Router service</help>
+              <valueless/>
+            </properties>
+          </leafNode>
+          <leafNode name="http-port">
+            <properties>
+              <help>HTTP redirect port</help>
+              <valueHelp>
+                <format>u32:1-65535</format>
+                <description>Port number</description>
+              </valueHelp>
+              <constraint>
+                <validator name="numeric" argument="--range 1-65535"/>
+              </constraint>
+            </properties>
+            <defaultValue>6300</defaultValue>
+          </leafNode>
+          <leafNode name="https-port">
+            <properties>
+              <help>HTTPS port for Web UI</help>
+              <valueHelp>
+                <format>u32:1-65535</format>
+                <description>Port number</description>
+              </valueHelp>
+              <constraint>
+                <validator name="numeric" argument="--range 1-65535"/>
+              </constraint>
+            </properties>
+            <defaultValue>6443</defaultValue>
+          </leafNode>
+          <leafNode name="config-dir">
+            <properties>
+              <help>Configuration directory</help>
+              <valueHelp>
+                <format>txt</format>
+                <description>Directory path</description>
+              </valueHelp>
+            </properties>
+            <defaultValue>/config/landscape</defaultValue>
+          </leafNode>
+        </children>
