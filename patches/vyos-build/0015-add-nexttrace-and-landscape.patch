From: VyOS Builder <builder@vyos.net>
Date: Sun, 27 Apr 2025 16:45:00 +0800
Subject: [PATCH] Add nexttrace repository and landscape-router package

Add nexttrace APT repository for amd64 architecture and landscape-router
package configuration.

---
 data/architectures/amd64.toml | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/data/architectures/amd64.toml b/data/architectures/amd64.toml
index 1234567..abcdefg 100644
--- a/data/architectures/amd64.toml
+++ b/data/architectures/amd64.toml
@@ -11,8 +11,21 @@ packages = [
   "amd64-microcode"
 ]

+[packages.landscape-router]
+  scm = "local"
+  architecture = "amd64"
+
 [boot_settings]
   console_type = "ttyS"
+
+[additional_repositories.nexttrace]
+  architecture = "amd64"
+  url = "https://github.com/nxtrace/nexttrace-debs/releases/latest/download"
+  distribution = "./"
+  components = ""
+  no_source = true
+  key = ""

 # vim: ft=toml
--
2.39.2
